# ============================================================
# SimpleMediaBrowser configuration
# Copy this file to .env and edit the values below.
# ============================================================

# --- Network ---
HOST=0.0.0.0
PORT=8080

# --- Security ---
# Generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# --- Media roots ---
# Semicolon-separated list of "Label=FullPath" pairs.
# The label is what users see in the UI; the path is the folder on disk.
# Windows example:
#   MEDIA_ROOTS=Movies=C:\Media\Movies;Photos=C:\Media\Photos
# Linux/macOS example:
#   MEDIA_ROOTS=Movies=/srv/media/movies;Photos=/srv/media/photos
MEDIA_ROOTS=Sample=C:\Media\Sample

# --- Users ---
# Semicolon-separated list of "username:password:group".
# Groups:
#   admin  -> read, upload, download, delete, create folder, delete folder
#   user   -> read, upload, download
#   guest  -> read only (see + view/stream)
USERS=admin:admin:admin;user:user:user;guest:guest:guest

# --- Uploads ---
# Maximum upload size per request, in megabytes.
MAX_UPLOAD_MB=2048
